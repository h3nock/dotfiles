# change window focus within space
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - h : yabai -m window --focus west
alt - l : yabai -m window --focus east
alt - u : ~/scripts/yabai-focus-history undo

# swap windows (keep tiling tree but exchange nodes)
shift + alt - h: yabai -m window --swap west
shift + alt - j: yabai -m window --swap south
shift + alt - k: yabai -m window --swap north
shift + alt - l: yabai -m window --swap east

# change focus between external displays (left and right)
alt - 0x21 : yabai -m display --focus west  # [
alt - 0x1E : yabai -m display --focus east  # ]

# move focused window to display left and right and follow it
shift + alt - 0x21 : yabai -m window --display west; yabai -m display --focus west;  # [
shift + alt - 0x1E : yabai -m window --display east; yabai -m display --focus east;  # ]

# move/remove current space
ctrl + shift + alt - p : yabai -m space --move prev
ctrl + shift + alt - n : yabai -m space --move next
ctrl + shift + alt - x : ~/dotfiles/scripts/scripts/yabai-destroy-empty-space

# rotate layout clockwise
shift + alt - r : yabai -m space --rotate 270

# flip along y-axis
shift + alt - y : yabai -m space --mirror y-axis

# flip along x-axis
shift + alt - x : yabai -m space --mirror x-axis

# expand/shrink width by 10px 
ctrl + shift + alt - l : yabai -m window --resize right:10:0
ctrl + shift + alt - h : yabai -m window --resize left:-10:0

# expand/shrink height by 10px 
ctrl + shift + alt - j : yabai -m window --resize bottom:0:10
ctrl + shift + alt - k : yabai -m window --resize top:0:-10

# maximize a window
shift + alt - f : yabai -m window --toggle zoom-fullscreen

# balance out tree of windows (resize to occupy same area)
shift + alt - e : yabai -m space --balance

# focus specific space
ctrl - 1 : yabai -m space --focus 1
ctrl - 2 : yabai -m space --focus 2
ctrl - 3 : yabai -m space --focus 3
ctrl - 4 : yabai -m space --focus 4
ctrl - 5 : yabai -m space --focus 5
ctrl - 6 : yabai -m space --focus 6

# focus adjacent spaces
ctrl - p : yabai -m space --focus prev
ctrl - n : yabai -m space --focus next

# move focused window to specific space, then follow (adds tiny delay to avoid races)
ctrl + shift + alt - 1 : wid="$(yabai -m query --windows --window | /opt/homebrew/bin/jq -r '.id')"; yabai -m window --space 1; sleep 0.20; yabai -m space --focus 1; sleep 0.10; yabai -m window --focus "$wid"; ~/scripts/yabai-focus-history sync
ctrl + shift + alt - 2 : wid="$(yabai -m query --windows --window | /opt/homebrew/bin/jq -r '.id')"; yabai -m window --space 2; sleep 0.20; yabai -m space --focus 2; sleep 0.10; yabai -m window --focus "$wid"; ~/scripts/yabai-focus-history sync
ctrl + shift + alt - 3 : wid="$(yabai -m query --windows --window | /opt/homebrew/bin/jq -r '.id')"; yabai -m window --space 3; sleep 0.20; yabai -m space --focus 3; sleep 0.10; yabai -m window --focus "$wid"; ~/scripts/yabai-focus-history sync
ctrl + shift + alt - 4 : wid="$(yabai -m query --windows --window | /opt/homebrew/bin/jq -r '.id')"; yabai -m window --space 4; sleep 0.20; yabai -m space --focus 4; sleep 0.10; yabai -m window --focus "$wid"; ~/scripts/yabai-focus-history sync
ctrl + shift + alt - 5 : wid="$(yabai -m query --windows --window | /opt/homebrew/bin/jq -r '.id')"; yabai -m window --space 5; sleep 0.20; yabai -m space --focus 5; sleep 0.10; yabai -m window --focus "$wid"; ~/scripts/yabai-focus-history sync
ctrl + shift + alt - 6 : wid="$(yabai -m query --windows --window | /opt/homebrew/bin/jq -r '.id')"; yabai -m window --space 6; sleep 0.20; yabai -m space --focus 6; sleep 0.10; yabai -m window --focus "$wid"; ~/scripts/yabai-focus-history sync

# floating window controls
shift + alt - space : yabai -m window --toggle float
shift + alt - p : yabai -m window --toggle float; yabai -m window --grid 4:4:1:1:2:2
ctrl + alt - h : yabai -m window --move rel:-50:0
ctrl + alt - j : yabai -m window --move rel:0:50
ctrl + alt - k : yabai -m window --move rel:0:-50
ctrl + alt - l : yabai -m window --move rel:50:0

# stop/start/restart yabai
ctrl + alt - q : yabai --stop-service
ctrl + alt - s : yabai --start-service
ctrl + alt - r : yabai --restart-service
