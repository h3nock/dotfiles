# reload scripting-addition on dock restart
sudo -n /opt/homebrew/bin/yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo -n /opt/homebrew/bin/yabai --load-sa"

# keep a per-space focus history for low-latency "undo focus" hotkeys
$HOME/scripts/yabai-focus-history sync
yabai -m signal --remove focus_history_space 2>/dev/null
yabai -m signal --remove focus_history_window 2>/dev/null
yabai -m signal --remove focus_history_window_destroyed 2>/dev/null
yabai -m signal --remove focus_history_space_destroyed 2>/dev/null
yabai -m signal --add event=space_changed label=focus_history_space action="$HOME/scripts/yabai-focus-history space \$YABAI_SPACE_ID"
yabai -m signal --add event=window_focused label=focus_history_window action="$HOME/scripts/yabai-focus-history window \$YABAI_WINDOW_ID"
yabai -m signal --add event=window_destroyed label=focus_history_window_destroyed action="$HOME/scripts/yabai-focus-history remove-window \$YABAI_WINDOW_ID"
yabai -m signal --add event=space_destroyed label=focus_history_space_destroyed action="$HOME/scripts/yabai-focus-history remove-space \$YABAI_SPACE_ID"

# default layout (can be bsp, stack or float)
yabai -m config layout bsp

# new window spawns to the right if vertical split, or bottom if horizontal split
yabai -m config window_placement second_child
# keep tiled windows flat while floating windows retain native macOS shadows
yabai -m config window_shadow float

# padding set
yabai -m config top_padding 10
yabai -m config bottom_padding 10
yabai -m config left_padding 10
yabai -m config right_padding 10
yabai -m config window_gap 10

# -- mouse settings --

# center mouse on window with focus
yabai -m config mouse_follows_focus on
# modifier for clicking and dragging with mouse
yabai -m config mouse_modifier alt
# set modifier + left-click drag to move window
yabai -m config mouse_action1 move
# set modifier + right-click drag to resize window
yabai -m config mouse_action2 resize

# when window is dropped in center of another window, swap them (on edges it will split it)
yabai -m config mouse_drop_action swap

# disable specific apps
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Karabiner-Elements$" manage=off
yabai -m rule --add app="^QuickTime Player$" manage=off
yabai -m rule --add app="^Spotify$" manage=off
yabai -m rule --add app="^Telegram$" manage=off
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^TickTick$" manage=off

# draw Catppuccin Mocha borders for the tiled workspace, excluding floating-style apps
border_blacklist="System Settings,Calculator,Karabiner-Elements,QuickTime Player,Spotify,Telegram,Finder,TickTick,Simulator"
/opt/homebrew/bin/borders \
  style=round \
  order=b \
  width=6.0 \
  hidpi=off \
  ax_focus=on \
  active_color=0xc0b4befe \
  inactive_color=0xc06c7086 \
  background_color=0x301e1e2e \
  blacklist="$border_blacklist" &

[ -r "$HOME/.yabairc.local" ] && source "$HOME/.yabairc.local"
